---
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<NavBar />
	<section class="about-section">
		<div class="about-container">
			<div class="about-content">
				<div class="content-block">
					<h2>About Advocate Jasvir Singh</h2>
					<p>
						Advocate Jasvir Singh is a practicing lawyer based in Noida and
						Greater Noida with extensive experience in handling civil, criminal,
						corporate, and consumer matters. He provides practical and
						result-oriented legal solutions tailored to each client's situation.
					</p>

					<p>
						With years of courtroom practice, he represents clients before
						district courts and other judicial authorities in matters involving
						dispute resolution, litigation, legal documentation, and advisory
						services.
					</p>

					<p>
						His approach focuses on clear legal guidance, strategic case
						preparation, and protecting the rights and interests of his clients
						at every stage of the legal process.
					</p>
				</div>

				<div class="content-block">
					<h3>Areas of Practice</h3>
					<p>
						Advocate Jasvir Singh provides legal services in the following areas:
					</p>
					<ul class="services-list">
						<li>Civil Law Matters</li>
						<li>Criminal Defense & Bail Matters</li>
						<li>Cyber Crime Cases</li>
						<li>Corporate, Trade & Industrial Disputes</li>
						<li>Consumer Protection & Dispute Cases</li>
						<li>Court Marriage Registration</li>
						<li>RERA Matters</li>
						<li>Property Registration & Documentation</li>
						<li>Notary & Legal Attestation Services</li>
					</ul>
				</div>

				<div class="content-block">
					<h3>Professional Approach</h3>
					<p>
						Every case is handled with confidentiality, careful legal analysis,
						and structured planning. Clients are provided with clear advice
						regarding legal options, possible outcomes, and procedural
						requirements.
					</p>

					<p>
						If you are seeking legal assistance in Noida or Greater Noida, you
						may schedule a consultation to discuss your matter in detail.
					</p>
				</div>
			</div>

			<div class="about-image">
				<img
					src="https://images.pexels.com/photos/7841442/pexels-photo-7841442.jpeg?_gl=1*6p4bp2*_ga*MTY1NTg0NzEwOC4xNzU4Mzg1MDk2*_ga_8JE65Q40S6*czE3NzE2ODAyNDYkbzYkZzEkdDE3NzE2ODAyNTYkajUwJGwwJGgw"
					alt="Advocate Jasvir Singh"
				/>
			</div>
		</div>
	</section>
	<Footer />
</Layout>

<style>
	.about-section {
		padding: 4rem 1rem;
		margin-top: 60px;
		background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
	}

	.about-container {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 4fr 3fr;
		gap: 3rem;
		align-items: center;
	}

	.about-content {
		display: flex;
		flex-direction: column-reverse;
		gap: 2rem;
	}

	.content-block h2 {
		font-size: 2rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1rem 0;
		line-height: 1.3;
	}

	.content-block h3 {
		font-size: 1.3rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 0.75rem 0;
	}

	.content-block p {
		margin: 0 0 1rem 0;
		color: #475569;
		line-height: 1.7;
		font-size: 1rem;
	}

	.content-block p:last-child {
		margin-bottom: 0;
	}

	.services-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		color: #475569;
	}

	.services-list li {
		padding-left: 1.5rem;
		position: relative;
	}

	.services-list li:before {
		content: "✓";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.2rem;
	}

	.about-image {
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		border-radius: 10px;
		background: #e2e8f0;
		height: 100%;
		min-height: 500px;
	}

	.about-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 300ms ease;
	}

	.about-image:hover img {
		transform: scale(1.03);
	}

	@media (max-width: 768px) {
		.about-container {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.about-image {
			min-height: 350px;
			order: 2;
		}

		.about-content {
			order: 1;
		}

		.content-block h2 {
			font-size: 1.6rem;
		}

		.content-block h3 {
			font-size: 1.1rem;
		}
	}

	@media (max-width: 480px) {
		.about-section {
			padding: 2rem 1rem;
		}

		.about-image {
			min-height: 280px;
		}

		.content-block h2 {
			font-size: 1.3rem;
		}

		.content-block p {
			font-size: 0.95rem;
		}
	}
</style>