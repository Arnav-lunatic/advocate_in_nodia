<style>
	.site-footer {
		background: #071025;
		color: #dbeafe;
		padding: 2.5rem 1rem 1.5rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 220px 240px;
		gap: 1.5rem;
		align-items: start;
	}

	.footer-brand .brand-title {
		color: #fff;
		text-decoration: none;
		font-weight: 800;
		font-size: 1.1rem;
	}

	.brand-highlight {
		background: #ffffff;
		color: #071025;
		padding: 0 0.45rem;
		font-weight: 900;
		border-radius: 3px;
	}

	.brand-desc { color: #9fb6d8; margin-top: 0.6rem; }

	.footer-links h4,
	.footer-contact h4 { margin: 0 0 0.6rem 0; color: #fff; }

	.footer-links ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
	.footer-links a { color: #cfe9ff; text-decoration: none; }

	.footer-contact address { font-style: normal; color: #9fb6d8; }
	.footer-contact a { color: #cfe9ff; text-decoration: none; }

	.footer-socials { display: flex; gap: 0.5rem; margin-top: 0.8rem; }
	.footer-socials .social { color: #cfe9ff; display: inline-flex; padding: 0.25rem; border-radius: 6px; }
	.footer-socials .icon { width: 20px; height: 20px; }

	.footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); margin-top: 1.25rem; padding-top: 1rem; text-align: center; color: #9fb6d8; font-size: 0.95rem; }

	@media (max-width: 900px) {
		.footer-container { grid-template-columns: 1fr 1fr; }
	}

	@media (max-width: 600px) {
		.footer-container { grid-template-columns: 1fr; }
		.footer-contact, .footer-links { order: 2; }
		.footer-brand { order: 1; }
		.footer-bottom { text-align: left; }
	}
</style>

