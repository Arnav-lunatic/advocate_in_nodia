<section class="hero">
	<div class="hero-content">
		<div class="hero-text">
			<h1>Experienced Lawyer in Noida</h1>

			<p>
				Expert legal representation for bail, FIR matters, court cases,
				and dispute resolution in Noida and Greater Noida.
			</p>

			<p>
				Advocate <a href="/about">Jasvir Singh</a> has years of courtroom experience and
				provides strategic legal solutions focused on protecting your
				rights and interests.
			</p>

			<a class="hero-cta" href="/contact" aria-label="Contact us">Contact  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M439.1 297.4C451.6 309.9 451.6 330.2 439.1 342.7L279.1 502.7C266.6 515.2 246.3 515.2 233.8 502.7C221.3 490.2 221.3 469.9 233.8 457.4L371.2 320L233.9 182.6C221.4 170.1 221.4 149.8 233.9 137.3C246.4 124.8 266.7 124.8 279.2 137.3L439.2 297.3z"/></svg>  </a>
		</div>
	</div>
	<div class="hero-image">
		<img src="/src/assets/black-wooden-gravel.jpg" alt="lawyer in Noida" />
	</div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: 3fr 4fr;
		gap: 0;
		gap: 2.5rem;
		padding: 4rem 0.5rem;
		overflow: hidden;
		height: 100vh;
		position: relative;
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
	}

	.hero-content {
		display: flex;
		align-items: flex-end;
		justify-content: flex-start;
		height: 100%;
	}

	.hero-text {
		max-width: 100%;
		padding: 3rem;
	}

	.hero-text h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1rem 0;
		line-height: 1.2;
	}

	.hero-text p {
		font-size: 1.1rem;
		color: #475569;
		margin: 0;
		line-height: 1.6;
	}

	.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;

  margin-top: 1rem;
  padding: 0.75rem 1.25rem;

  background: #0ea5a4;
  color: #fff;
  font-weight: 700;
  border-radius: 8px;
  text-decoration: none;

  box-shadow: 0 6px 18px rgba(14,165,164,0.12);
  transition: all 0.25s ease;
}

.hero-cta::after {
  content: "→";  
  font-size: 1.1rem;
  transition: transform 0.25s ease;
}

.hero-cta:hover::after {
  transform: translateX(5px);
}

	.hero-image {
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		height: 100%;
		background: #e2e8f0;
		border-radius: 10px;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 300ms ease, filter 300ms ease;
	}

	.hero-image img:hover {
		transform: scale(1.05);
		filter: brightness(1.1);
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			height: auto;
		}

		.hero-content {
			min-height: 300px;
			padding: 1.5rem;
			order: 2;
		}

		.hero-image {
			min-height: 300px;
			max-height: 400px;
			order: 1;
		}

		.hero-text {
			padding: 0;
		}

		.hero-text h1 {
			font-size: 1.8rem;
		}

		.hero-text p {
			font-size: 1rem;
		}
	}

	@media (max-width: 480px) {
		.hero-text h1 {
			font-size: 1.4rem;
		}
		.hero-text {
			padding: 0;
		}

		.hero-text p {
			font-size: 0.9rem;
		}

		.hero-content {
			min-height: 250px;
			padding: 1rem;
		}

		.hero-image {
			min-height: 200px;
		}
	}
</style>
