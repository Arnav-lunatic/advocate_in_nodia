<section class="team-section">
	<div class="team-container">
		<div class="team-header">
			<h2>Our Associated Members</h2>
			<p>Professional legal team dedicated to serving your legal needs with expertise and integrity.</p>
		</div>

		<div class="team-grid">
			<!-- Team Member Card 1 -->
			<article class="team-card">
				<div class="card-image">
					<img src="/src/assets/advocate1.jpg" alt="Team Member" />
				</div>
				<div class="card-content">
					<h3 class="member-name">Kavindra Singh</h3>
					<p class="member-role">Advocate</p>
					<a href="tel:+919876543210" class="member-phone">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
							<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
						</svg>
						+91 9958 581 518
					</a>
				</div>
			</article>
		</div>
	</div>
</section>

<style>
	.team-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 4rem 1rem;
		min-height: auto;
	}

	.team-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.team-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.team-header h2 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1rem 0;
		line-height: 1.2;
	}

	.team-header p {
		font-size: 1.1rem;
		color: #475569;
		margin: 0;
		max-width: 700px;
		margin: 0 auto;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-top: 2rem;
	}

	.team-card {
		background: white;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		transition: all 0.3s ease;
		display: flex;
		flex-direction: column;
        max-width: 30%;
	}

	.team-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 30px rgba(14, 165, 164, 0.15);
	}

	.card-image {
		width: 100%;
		height: 360px;
		overflow: hidden;
		background: #e2e8f0;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.team-card:hover .card-image img {
		transform: scale(1.08);
	}

	.card-content {
		padding: 2rem 1.5rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.member-name {
		font-size: 1.3rem;
		font-weight: 700;
		color: #0f172a;
		margin: 0;
		line-height: 1.3;
	}

	.member-role {
		font-size: 0.95rem;
		color: #0ea5a4;
		font-weight: 600;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.member-phone {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1rem;
		color: #475569;
		text-decoration: none;
		transition: all 0.3s ease;
		margin-top: 0.5rem;
		width: fit-content;
	}

	.member-phone svg {
		color: #0ea5a4;
		flex-shrink: 0;
	}

	.member-phone:hover {
		color: #0ea5a4;
		transform: translateX(4px);
	}

	.member-phone:hover svg {
		transform: scale(1.15);
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.team-section {
			padding: 2rem 1rem;
		}

		.team-header h2 {
			font-size: 1.8rem;
		}

		.team-header p {
			font-size: 1rem;
		}

		.team-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.card-image {
			height: 250px;
		}

		.card-content {
			padding: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.team-header h2 {
			font-size: 1.5rem;
		}

		.team-header p {
			font-size: 0.9rem;
		}

		.card-image {
			height: 220px;
		}

		.member-name {
			font-size: 1.1rem;
		}

		.member-role {
			font-size: 0.85rem;
		}

		.member-phone {
			font-size: 0.9rem;
		}
	}
</style>
