---
import heroImage from '../assets/notary_lawyer_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Certified Notary Public &amp; Legal Attestation in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Notary Lawyer in Noida</h1>
				
				<p class="intro-text">
					Official legal documentation, commercial contracts, and international affidavits require authenticated credibility to stand in court and before administrative authorities. Our certified Notary Public and legal attestation services in Noida provide fast, precise, and highly compliant validation for all your legal declarations.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Affidavit Attestation:</strong> Preparation and certified attestation of affidavits for name changes, address proof, marriage registries, and financial declarations
					</li>
					<li>
						<strong>Agreement Notarization:</strong> Authenticating rent agreements, commercial lease deeds, partnership agreements, and business contracts
					</li>
					<li>
						<strong>Power of Attorney Verification:</strong> Witnessing, drafting, and notarizing General Power of Attorney (GPA) and Special Power of Attorney (SPA) documents
					</li>
					<li>
						<strong>Certified True Copies:</strong> Providing official notary attestation for photocopies of passports, educational marksheets, birth certificates, and ID cards
					</li>
					<li>
						<strong>Oaths &amp; Statutory Declarations:</strong> Administering legal oaths, affirmations, and statutory declarations under the Notaries Act, 1952
					</li>
					<li>
						<strong>Signature Attestation:</strong> Official verification and notarization of signatures on domestic property deeds and commercial transaction documents
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Legal documentation must be executed in absolute accordance with national notary laws to prevent future cancellation or evidentiary challenges. We offer:
				</p>
				<ul class="benefits-list">
					<li>Certified, government-authorized Notary Public credentials with official register stamps</li>
					<li>Fast, error-free drafting of customized legal agreements, affidavits, and declarations</li>
					<li>Complete compliance with state stamp duty regulations and the Indian Oaths Act</li>
					<li>A convenient office location in Greater Noida and Jewar for immediate, same-day attestation support</li>
					<li>Secure verification protocols to guarantee the authenticity of signed instruments</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					We handle notary attestations through a secure and authorized process, ensuring each document is legally recognized. We:
				</p>
				<ol class="approach-list">
					<li>Verify client identity using valid government-issued photographic ID proofs</li>
					<li>Review the affidavit or agreement text to ensure complete compliance with legal drafting laws</li>
					<li>Confirm the appropriate stamp papers are attached and stamp duties paid online</li>
					<li>Record transaction serial numbers and client signatures in the official Notary Register</li>
					<li>Witness the client signing in person and apply the official embossed Notary Seal and stamps</li>
					<li>Issue the notarized document, complete with registry entry details and verification coordinates</li>
				</ol>

				<h2>Get Certified Legal Attestations</h2>
				<p>
					If you need verified agreements, notarized powers of attorney, or certified copies for official submissions, we can assist with:
				</p>
				<ul class="complaint-list">
					<li>Notarizing rent agreements and commercial leases for corporate offices</li>
					<li>Attesting visa affidavits, sponsorship declarations, and marriage proofs</li>
					<li>Drafting and notarizing Special Power of Attorney for property sales</li>
					<li>Verifying and attesting corporate resolutions and authority declarations</li>
				</ul>

				<div class="cta-section">
					<p>Need immediate notary public attestation or affidavit drafting? Contact us for a fast, certified same-day service.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/court-marriage" class="service-link">
							Court Marriage Registration
						</a>
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/revenue-matters" class="service-link">
							Revenue &amp; Administrative Matters
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link active">
							Notary Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
