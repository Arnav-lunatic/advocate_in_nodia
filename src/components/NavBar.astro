<div id="drawer-overlay" class="drawer-overlay" hidden></div>

<style>
	:root {
		--nav-bg: transparent;
		--text: #0f172a;
		--muted: #475569;
		--drawer-bg: #ffffff;
	}
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6rem 1rem;
		gap: 1rem;
		margin: 0 auto;
		background: #ffffff;
		box-shadow: 0 2px 8px rgba(2, 6, 23, 0.08);
		z-index: 100;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.drawer-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		border: none;
		padding: 0.25rem;
		margin-right: 0.25rem;
		cursor: pointer;
		color: var(--muted);
	}
	.drawer-toggle:focus {
		outline: 2px solid rgba(59, 130, 246, 0.6);
		border-radius: 6px;
	}
	.brand-title {
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		font-size: 1.1rem;
	}
	.controls {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.8rem;
	}
	.link {
		color: var(--muted);
		text-decoration: none;
		padding: 0.35rem 0.6rem;
		border-radius: 6px;
		font-weight: 600;
	}
	.link:hover {
		background: rgba(15, 23, 42, 0.06);
		color: var(--text);
	}

	/* Drawer styles */
	.drawer {
		position: fixed;
		right: 0;
		top: 0;
		height: 100vh;
		width: 280px;
		max-width: 85vw;
		background: var(--drawer-bg);
		box-shadow: -2px 0 12px rgba(2, 6, 23, 0.1);
		transform: translateX(110%);
		transition: transform 240ms ease;
		z-index: 50;
		display: flex;
		flex-direction: column;
		padding: 1rem;
	}
	.drawer.open {
		transform: translateX(0%);
	}
	.drawer-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1rem;
	}
	.drawer-close {
		background: transparent;
		border: none;
		font-size: 1.1rem;
		cursor: pointer;
	}
	.drawer-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.drawer-link {
		padding: 0.6rem 0.5rem;
		color: var(--text);
		text-decoration: none;
		border-radius: 6px;
		font-weight: 600;
	}
	.drawer-link:hover {
		background: rgba(2, 6, 23, 0.04);
	}

	/* Drawer Services Dropdown */
	.services-dropdown-drawer {
		margin: 0;
		padding: 0;
		border: none;
	}

	.services-dropdown-drawer[open] > summary {
		background: rgba(2, 6, 23, 0.04);
		color: var(--text);
	}

	.services-dropdown-drawer summary {
		list-style: none;
		outline: none;
		cursor: pointer;
		padding: 0.6rem 0.5rem;
		color: var(--text);
		font-weight: 600;
		border-radius: 6px;
		transition: background 0.15s;
	}

	.services-dropdown-menu-drawer {
		margin: 0.2rem 0 0 0.5rem;
		padding: 0.2rem 0;
		background: var(--drawer-bg);
		border-radius: 6px;
		box-shadow: 0 2px 8px rgba(2, 6, 23, 0.06);
		border: 1px solid rgba(2, 6, 23, 0.06);
		min-width: 180px;
		max-width: 95%;
	}

	.services-dropdown-menu-drawer li {
		border-bottom: 1px solid rgba(2, 6, 23, 0.06);
	}
	.services-dropdown-menu-drawer li:last-child {
		border-bottom: none;
	}

	.services-dropdown-menu-drawer .drawer-link {
		display: block;
		padding: 0.55rem 1rem;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.95rem;
		border-radius: 6px;
		transition: background 0.15s, color 0.15s;
	}
	.services-dropdown-menu-drawer .drawer-link:hover,
	.services-dropdown-menu-drawer .drawer-link:focus {
		background: rgba(15, 23, 42, 0.06);
		color: var(--text);
		outline: none;
	}

	.drawer-socials {
		margin: auto auto 0 auto;
		padding-top: 1rem;
		border-top: 1px solid rgba(2, 6, 23, 0.1);
	}

	.drawer-overlay {
		position: fixed;
		inset: 0;
		background: rgba(2, 6, 23, 0.4);
		z-index: 40;
	}

	@media (min-width: 721px) {
		.drawer-toggle {
			display: none;
		}
		.drawer-socials {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.links {
			display: none;
		}
		.socials {
			display: none;
		}
		.brand-title {
			font-size: 0.95rem;
		}
	}

	@media (max-width: 720px) {
		.socials {
			display: none;
		}
	}

	nav ul {
		list-style: none;
		display: flex;
		gap: 2rem;
	}

	nav ul li {
		position: relative;
	}

	/* Services dropdown - themed to site variables */
	.services-dropdown {
		list-style: none;
		position: relative;
	}

	.services-dropdown > a {
		color: var(--muted);
		text-decoration: none;
		padding: 0.35rem 0.6rem;
		border-radius: 6px;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.services-dropdown > a:hover,
	.services-dropdown > a:focus {
		background: rgba(15, 23, 42, 0.06);
		color: var(--text);
		outline: none;
	}

	.services-dropdown-menu {
		position: absolute;
		display: flex;
		flex-direction: column;
		top: calc(100% + 8px);
		left: 0;
		background: var(--drawer-bg);
		min-width: 220px;
		max-width: 320px;
		padding: 0.25rem;
		margin: 0;
		border-radius: 8px;
		box-shadow: 0 8px 20px rgba(2, 6, 23, 0.12);
		border: 1px solid rgba(2, 6, 23, 0.06);
		overflow: hidden;
		pointer-events: none;

		opacity: 0;
		visibility: hidden;
		transform: translateY(6px);
		transition:
			opacity 180ms ease,
			transform 180ms ease;
		z-index: 120;
	}

	.services-dropdown-menu li {
		border-bottom: 1px solid rgba(2, 6, 23, 0.06);
	}

	.services-dropdown-menu li:last-child {
		border-bottom: none;
	}

	.services-dropdown-menu a {
		display: block;
		padding: 10px 14px;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9rem;
		border-radius: 6px;
	}

	.services-dropdown-menu a:hover,
	.services-dropdown-menu a:focus {
		background: rgba(15, 23, 42, 0.04);
		color: var(--text);
		outline: none;
	}

	/* show on hover or keyboard focus */
	.services-dropdown:hover .services-dropdown-menu,
	.services-dropdown:focus-within .services-dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		pointer-events: auto;
	}
</style>

<script is:inline>
	(function () {
		const toggle = document.querySelector(".drawer-toggle");
		const drawer = document.querySelector(".drawer");
		const overlay = document.getElementById("drawer-overlay");
		const closeBtn = document.querySelector(".drawer-close");

		function open() {
			drawer.classList.add("open");
			drawer.setAttribute("aria-hidden", "false");
			toggle.setAttribute("aria-expanded", "true");
			overlay.hidden = false;
			document.body.style.overflow = "hidden";
			drawer.querySelector("a")?.focus();
		}

		function close() {
			drawer.classList.remove("open");
			drawer.setAttribute("aria-hidden", "true");
			toggle.setAttribute("aria-expanded", "false");
			overlay.hidden = true;
			document.body.style.overflow = "";
			toggle.focus();
		}

		toggle?.addEventListener("click", open);
		closeBtn?.addEventListener("click", close);
		overlay?.addEventListener("click", close);
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && drawer.classList.contains("open"))
				close();
		});
	})();
</script>
