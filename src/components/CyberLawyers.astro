<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src="https://images.pexels.com/photos/3807517/pexels-photo-3807517.jpeg?auto=compress&cs=tinysrgb&w=1600" 
				alt="Cyber Crime Lawyer" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Cyber Crime Lawyer in Noida</h1>
				
				<p class="intro-text">
					In today's digital age, cyber crimes are increasingly prevalent. Whether you're facing charges of online fraud, data theft, cyberbullying, or any other cyber-related offense, our experienced cyber crime lawyers in Noida provide expert legal representation and guidance.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Cyber Fraud Cases:</strong> Representation in financial fraud, phishing scams, and online theft cases
					</li>
					<li>
						<strong>Data Breach & Privacy Violations:</strong> Legal support for unauthorized data access and privacy infringements
					</li>
					<li>
						<strong>Online Harassment & Cyberbullying:</strong> Protection against defamation, harassment, and abusive online behavior
					</li>
					<li>
						<strong>IT Act Violations:</strong> Defense against charges under Information Technology Act, 2000
					</li>
					<li>
						<strong>Identity Theft:</strong> Assistance in cases involving illegal use of personal identity online
					</li>
					<li>
						<strong>Intellectual Property Theft:</strong> Protection against unauthorized use of digital content and intellectual property
					</li>
					<li>
						<strong>Cryptocurrency & Financial Scams:</strong> Guidance in cases involving digital currency fraud
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Cyber crime cases require specialized knowledge of both information technology and law. Our advocates have extensive experience in:
				</p>
				<ul class="benefits-list">
					<li>Understanding complex technical aspects of cyber crimes</li>
					<li>Gathering and preserving digital evidence</li>
					<li>Navigating cybercrime laws and IT Act provisions</li>
					<li>Defending clients in cyber crime courts and tribunals</li>
					<li>Filing FIRs and pursuing cyber crime complaints</li>
					<li>Providing strategic legal advice throughout the process</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					Every cyber crime case is unique and requires careful analysis of digital evidence, technical details, and legal implications. We:
				</p>
				<ol class="approach-list">
					<li>Conduct thorough investigation of the cyber incident</li>
					<li>Analyze evidence collected by law enforcement agencies</li>
					<li>Develop a comprehensive legal strategy tailored to your case</li>
					<li>Represent you in all proceedings with expert advocacy</li>
					<li>Protect your rights while navigating complex cyber laws</li>
					<li>Pursue fair resolution and justice on your behalf</li>
				</ol>

				<h2>File a Cyber Crime Complaint</h2>
				<p>
					If you are a victim of cyber crime, we can assist you in filing a complaint with:
				</p>
				<ul class="complaint-list">
					<li>Local Police Cyber Crime Division</li>
					<li>Cyber Crime Reporting Portal (cybercrime.gov.in)</li>
					<li>Indian Computer Emergency Response Team (CERT-IN)</li>
					<li>RBI / Bank authorities (for financial cyber crimes)</li>
				</ul>

				<div class="cta-section">
					<p>Need expert cyber crime legal assistance? Contact us for a consultation.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/cyber-lawyers" class="service-link active">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
						<a href="/rera-lawyer" class="service-link">
							RERA Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
