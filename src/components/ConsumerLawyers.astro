---
import heroImage from '../assets/consumer_protection_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Consumer Protection Lawyer in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Consumer Protection Lawyer in Noida</h1>
				
				<p class="intro-text">
					Every consumer has the fundamental right to quality products, transparent services, and fair trade practices. When corporations, insurance providers, or builders fall short, our dedicated consumer protection lawyers in Noida stand ready to represent your grievances, recover losses, and secure rightful compensation.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Product Liability &amp; Defects:</strong> Filing claims against manufacturers, distributors, or e-commerce portals for unsafe, sub-standard, or defective goods
					</li>
					<li>
						<strong>Service Deficiency Claims:</strong> Representation against telecom providers, banks, medical institutions, and schools for negligent services
					</li>
					<li>
						<strong>Real Estate Builder Disputes:</strong> Expert legal action under Consumer Forums against developers for delayed flat possession or substandard construction
					</li>
					<li>
						<strong>Insurance Claim Denials:</strong> Direct legal action against insurance companies for wrongful repudiation of medical, life, motor, or property claims
					</li>
					<li>
						<strong>Unfair Trade Practices:</strong> Redressal for false advertising, overcharging, hidden charges, and predatory corporate terms
					</li>
					<li>
						<strong>Consumer Forum Representation:</strong> Complete litigation support before District, State, and National Consumer Dispute Redressal Commissions (NCDRC)
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Filing complaints against large corporations and insurance companies requires absolute procedural accuracy and a heavy reliance on legal evidence. Our advocates offer:
				</p>
				<ul class="benefits-list">
					<li>In-depth expertise in the Consumer Protection Act, 2019 and e-commerce rules</li>
					<li>Proven track record of securing robust compensation and refund orders</li>
					<li>Strategic drafting of direct, heavy-hitting legal notices to push for early settlements</li>
					<li>Skilled representation before the Consumer Commission at all levels</li>
					<li>Representation for both retail individual consumers and corporate commercial clients</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					We make sure that corporate entities are held accountable for sub-standard products and services by utilizing a structured legal protocol. We:
				</p>
				<ol class="approach-list">
					<li>Analyze transactional records, bills, service agreements, and correspondence</li>
					<li>Draft and serve a formal Legal Notice demanding rectifications or refunds</li>
					<li>File a detailed, evidence-backed Consumer Complaint in the relevant jurisdiction</li>
					<li>Confidently present oral arguments and submit written declarations in court</li>
					<li>Advocate for maximum compensation, litigation expenses, and damages for mental harassment</li>
					<li>File execution applications to enforce compliance with court judgments</li>
				</ol>

				<h2>Protect Your Rights as a Consumer</h2>
				<p>
					If you have been cheated by a business, received defective products, or faced poor service, we can assist you with:
				</p>
				<ul class="complaint-list">
					<li>Drafting professional pre-litigation Legal Demand Notices</li>
					<li>Filing formal complaints on the Central Consumer Protection Authority (CCPA) portal</li>
					<li>Representing your case in District Consumer Commissions in Noida and Greater Noida</li>
					<li>Filing appeals in State or National Consumer Disputes Redressal Commissions</li>
				</ul>

				<div class="cta-section">
					<p>Have you suffered financial loss due to a builder, merchant, or insurance company? Contact us to seek justice and compensation.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/court-marriage" class="service-link">
							Court Marriage Registration
						</a>
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link active">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/revenue-matters" class="service-link">
							Revenue &amp; Administrative Matters
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
