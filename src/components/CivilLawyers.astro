---
import heroImage from '../assets/civil_lawyer_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Civil Lawyer in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Civil Lawyer in Noida</h1>
				
				<p class="intro-text">
					Civil disputes, ranging from complex property litigation and inheritance disputes to contract breaches, require a meticulously planned legal strategy. Our civil litigation team in Noida specializes in representing individuals and organizations before all civil courts, delivering robust advocacy to secure your properties, assets, and legal rights.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Property &amp; Land Disputes:</strong> Representation in partition suits, ancestral property claims, boundary disputes, and land encroachment matters
					</li>
					<li>
						<strong>Money Recovery Suits:</strong> Fast-track litigation for recovering commercial dues, personal loans, business debts, and security deposits
					</li>
					<li>
						<strong>Injunctions &amp; Stay Orders:</strong> Securing urgent temporary or permanent injunctions to safeguard property possession and stop illegal construction
					</li>
					<li>
						<strong>Specific Performance of Contracts:</strong> Pursuing legal enforcement for commercial agreements, sales agreements, and developer commitments
					</li>
					<li>
						<strong>Succession, Wills &amp; Probate:</strong> Meticulous drafting and litigation for wills, succession certificates, inheritance claims, and probate petitions
					</li>
					<li>
						<strong>Landlord-Tenant Litigations:</strong> Legal remedies for unlawful tenant eviction, non-payment of rent, and lease agreement violations
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Civil law requires a comprehensive understanding of procedural guidelines (CPC) and detailed historical property laws. Our firm excels by offering:
				</p>
				<ul class="benefits-list">
					<li>18+ years of dedicated courtroom practice in civil and property litigation</li>
					<li>Meticulous analysis of historical title deeds, chain documents, and revenue records</li>
					<li>Strong dispute resolution skills aimed at achieving out-of-court settlements</li>
					<li>Aggressive execution of court decrees to recover monies and secure possessions</li>
					<li>Representation before Sub-Divisional Magistrates (SDM), District Courts, and High Courts</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					We approach civil disputes through a strategic and document-heavy process to secure solid positions in courtroom trials. We:
				</p>
				<ol class="approach-list">
					<li>Perform a comprehensive legal audit of all property deeds, registries, and agreement clauses</li>
					<li>Draft and serve precise Legal Demand Notices to resolve disputes amicably where possible</li>
					<li>Draft and file structured Plaints or Written Statements under the Civil Procedure Code</li>
					<li>Secure immediate stay orders and interim injunctions to protect client assets</li>
					<li>Confidently lead examinations, cross-examinations, and present key documentary evidence</li>
					<li>Relentlessly pursue the execution of favorable court judgments and decrees</li>
				</ol>

				<h2>Resolve Your Civil Disputes</h2>
				<p>
					If you are facing an active land dispute, tenancy issue, or need to recover outstanding money, we can assist you with:
				</p>
				<ul class="complaint-list">
					<li>Filing Money Recovery Suits under Order 37 of the CPC</li>
					<li>Filing Partition Suits for ancestral or joint family properties</li>
					<li>Drafting legally binding Wills, Gift Deeds, and Trust Deeds</li>
					<li>Filing eviction petitions and rent recovery claims before local rent authorities</li>
				</ul>

				<div class="cta-section">
					<p>Need professional civil legal counsel or facing a property dispute? Contact us to schedule an expert consultation.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link active">
							Civil Lawyer
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
						<a href="/rera-lawyer" class="service-link">
							RERA Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
