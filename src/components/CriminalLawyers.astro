---
import heroImage from '../assets/criminal_lawyer_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Criminal Lawyer in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Criminal Lawyer in Noida</h1>
				
				<p class="intro-text">
					In a challenging legal environment, facing criminal allegations or handling a police investigation can be extremely stressful. Whether you need bail, are facing trial, or want to protect your fundamental rights, our team of highly experienced criminal defense lawyers in Noida is committed to providing authoritative, robust, and strategic legal representation.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Bail &amp; Anticipatory Bail:</strong> Strategic representation for obtaining regular bail, anticipatory bail, or interim bail in District Courts, High Courts, and the Supreme Court
					</li>
					<li>
						<strong>FIR Matters &amp; Investigations:</strong> Defense counsel during active police investigations, questioning, and filing for FIR quashing
					</li>
					<li>
						<strong>Criminal Trial Defense:</strong> Experienced advocacy for cases involving theft, assault, white-collar crimes, fraud, and trespass
					</li>
					<li>
						<strong>Cheque Bounce Cases (Section 138):</strong> Robust prosecution or defense for cheque bounce disputes under the Negotiable Instruments Act
					</li>
					<li>
						<strong>Matrimonial &amp; Domestic Violence:</strong> Dedicated legal handling of domestic violence, dowry allegations (Section 498A), and maintenance claims
					</li>
					<li>
						<strong>Appeals &amp; Revisions:</strong> Filing and contesting criminal appeals, revision petitions, and special leave petitions in higher courts
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Criminal cases demand extensive legal acumen, meticulous attention to detail, and a deep understanding of police procedures and court trial operations. Our advocates offer:
				</p>
				<ul class="benefits-list">
					<li>18+ years of extensive courtroom trial and litigation experience</li>
					<li>Meticulous analysis of charge sheets, FIRs, and prosecution evidence</li>
					<li>Relentless, highly persuasive, and protective courtroom defense advocacy</li>
					<li>Absolute confidentiality and transparent counsel on legal outcomes</li>
					<li>Immediate and tactical guidance during police questioning and custody</li>
					<li>Expertise in both procedural laws (CrPC/BNSS) and substantive laws (IPC/BNS)</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					Every criminal defense case is treated with critical care and structured planning to secure our clients' rights and liberty. We:
				</p>
				<ol class="approach-list">
					<li>Conduct a thorough case evaluation and extract vital defense evidence</li>
					<li>Identify vulnerabilities, loopholes, and inconsistencies in the prosecution's case</li>
					<li>Formulate a tailored courtroom defense and cross-examination strategy</li>
					<li>Represent clients at all stages of judicial, magistrate, and police proceedings</li>
					<li>Actively prevent arbitrary arrests and protect constitutional rights</li>
					<li>Pursue a fair trial and the swiftest possible legal relief or acquittal</li>
				</ol>

				<h2>Get Immediate Criminal Defense Help</h2>
				<p>
					If you or a loved one is dealing with an active criminal investigation, police notice, or prosecution, we can assist you in:
				</p>
				<ul class="complaint-list">
					<li>Filing Anticipatory Bail applications before the Sessions Court</li>
					<li>Drafting regular bail and representing you during hearings</li>
					<li>Filing quashing petitions (Section 482 CrPC / BNSS) before the High Court</li>
					<li>Drafting representations before police authorities to prevent illegal custody</li>
				</ul>

				<div class="cta-section">
					<p>Facing criminal allegations or need urgent bail assistance? Contact us immediately for a professional consultation.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link active">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
						<a href="/rera-lawyer" class="service-link">
							RERA Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
