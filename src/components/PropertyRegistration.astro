---
import heroImage from '../assets/property_registration_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Property Registration &amp; Title Verification in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Property Registration in Noida</h1>
				
				<p class="intro-text">
					Acquiring property is a significant milestone that demands absolute legal diligence to ensure secure ownership. Our expert property lawyers in Noida manage the entire legal spectrum of title verification, document vetting, stamp duty calculation, and secure deed registration at the Sub-Registrar's Office.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Property Title Search &amp; Due Diligence:</strong> 13 to 30-year historical title verification of ownership, chain deeds, and bank encumbrances
					</li>
					<li>
						<strong>Drafting &amp; Vetting of Deeds:</strong> Precision drafting of Sale Deeds, Lease Deeds, Gift Deeds, Relinquishment Deeds, and Power of Attorney
					</li>
					<li>
						<strong>Sub-Registrar Coordination:</strong> End-to-end management of biometric registration appointments at Noida, Greater Noida, and Yamuna Expressway registry offices
					</li>
					<li>
						<strong>Stamp Duty Advisory:</strong> Expert calculation of precise stamp duty rates, registration fees, and local development charges to avoid penalties
					</li>
					<li>
						<strong>Builder-Buyer Agreement Vetting:</strong> Comprehensive review of builder contracts to identify hidden charges and one-sided penalty terms
					</li>
					<li>
						<strong>Mutation of Property (Dakhil Kharij):</strong> Updating municipal, revenue, and local authority land records after registry execution
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Property registration is not just a administrative formality; it is a critical process to establish clean, unencumbered land ownership. We guarantee:
				</p>
				<ul class="benefits-list">
					<li>Absolute fraud prevention by identifying double allotments, land disputes, and fake registries</li>
					<li>Seamless, transparent, and hassle-free processing at the Sub-Registrar's Office</li>
					<li>Compliance with RERA guidelines, UP Apartment Act, and local Authority master plans</li>
					<li>Clear, secure drafting that prevents future boundary or inheritance litigation</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					We handle property registration through a structured and error-free legal protocol to protect your lifetime investment. We:
				</p>
				<ol class="approach-list">
					<li>Collect all historical title chain deeds, mutation records, and allotment certificates</li>
					<li>Draft a formal Title Search Report verifying the property's clean and sellable status</li>
					<li>Draft the Sale Deed or Lease Deed with strong covenants to protect the buyer's interests</li>
					<li>Supervise secure online stamp duty payments and schedule the Registrar's slot</li>
					<li>Accompany the buyer and seller to the Sub-Registrar's Office to execute registration</li>
					<li>Obtain the original registered Sale Deed and execute mutation in local government databases</li>
				</ol>

				<h2>Secure Your Real Estate Registry</h2>
				<p>
					Whether you are purchasing a residential flat, commercial plot, or agricultural land in Noida, we assist in:
				</p>
				<ul class="complaint-list">
					<li>Vetting properties in Noida, Greater Noida, Jewar, and Yamuna Expressway</li>
					<li>Drafting legally sound Agreement to Sell documents</li>
					<li>Calculating flat registration costs under the latest circle rates</li>
					<li>Executing Mutation filings before the local development authority and Tehsil</li>
				</ul>

				<div class="cta-section">
					<p>Ready to purchase a property or need immediate title verification? Contact us for a safe, expert registration service.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/court-marriage" class="service-link">
							Court Marriage Registration
						</a>
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/revenue-matters" class="service-link">
							Revenue &amp; Administrative Matters
						</a>
						<a href="/property-registration" class="service-link active">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
