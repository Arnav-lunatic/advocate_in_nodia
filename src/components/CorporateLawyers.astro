---
import heroImage from '../assets/corporate_disputes_hero.png';
---

<section class="service-detail-section">
	<div class="service-detail-container">
		<!-- Hero Image -->
		<div class="service-hero">
			<img 
				src={heroImage.src} 
				alt="Corporate &amp; Industrial Disputes Lawyer in Noida" 
			/>
		</div>

		<!-- Main Content and Sidebar -->
		<div class="service-content-wrapper">
			<!-- Main Content -->
			<div class="service-main-content">
				<h1>Corporate &amp; Industrial Disputes Lawyer in Noida</h1>
				
				<p class="intro-text">
					Navigating commercial conflicts and industrial compliance requires a rigorous understanding of corporate law, business operations, and labour regulations. Our team provides tactical, result-oriented legal counsel to safeguard your enterprise, resolve partnership conflicts, and protect your commercial interests.
				</p>

				<h2>What We Handle</h2>
				<ul class="service-features">
					<li>
						<strong>Business Contract Disputes:</strong> Representation in commercial breaches, non-disclosure agreement violations, and supplier or client contract disputes
					</li>
					<li>
						<strong>Partnership &amp; Shareholder Conflicts:</strong> Expert resolution of conflicts between business partners, directors, shareholders, and investors
					</li>
					<li>
						<strong>Industrial &amp; Labour Disputes:</strong> Comprehensive defense and compliance counsel for labour claims, wages, and trade union disputes
					</li>
					<li>
						<strong>Trademark &amp; IP Litigation:</strong> Securing and defending copyrights, patents, trademarks, and trade secrets in Noida
					</li>
					<li>
						<strong>Debt Recovery &amp; Insolvency:</strong> Recovering commercial dues through the MSME Act, NCLT, and the Insolvency and Bankruptcy Code (IBC)
					</li>
					<li>
						<strong>Commercial Arbitration &amp; Mediation:</strong> Representation in corporate dispute arbitrations to resolve conflicts efficiently out of court
					</li>
				</ul>

				<h2>Why Choose Our Firm</h2>
				<p>
					Corporate disputes demand a combination of commercial pragmatism and sharp legal advocacy. We specialize in providing businesses with:
				</p>
				<ul class="benefits-list">
					<li>Deep legal expertise in Indian corporate law, NCLT proceedings, and labor tribunals</li>
					<li>A pragmatic approach focused on minimizing operational disruption and financial exposure</li>
					<li>Proactive contract drafting and risk assessment to prevent future litigation</li>
					<li>Strong negotiation and alternative dispute resolution (ADR) skills</li>
					<li>Skilled courtroom advocacy for commercial litigation in Noida and higher courts</li>
				</ul>

				<h2>Our Approach</h2>
				<p>
					We analyze every commercial dispute through both a legal and business lens to secure the most favorable outcome for your enterprise. We:
				</p>
				<ol class="approach-list">
					<li>Conduct a thorough review of relevant business contracts, NDAs, and corporate policies</li>
					<li>Evaluate liability risk and design a customized legal strategy for negotiation or litigation</li>
					<li>Engage in professional mediation or arbitration first to resolve disputes out of court</li>
					<li>Draft compelling pleadings, notices, and representations for corporate matters</li>
					<li>Represent the business aggressively before judicial authorities and tribunals</li>
					<li>Implement compliance mechanisms to prevent recurrence of corporate and labour disputes</li>
				</ol>

				<h2>Protect Your Business Operations</h2>
				<p>
					Whether you are a startup, SME, or an industrial unit in Noida, we can help protect your business through:
				</p>
				<ul class="complaint-list">
					<li>Drafting and responding to legal notices for breach of contract</li>
					<li>Filing commercial debt recovery suits under the MSME Act or NCLT</li>
					<li>Representing your firm before the Labour Commissioner and Industrial Tribunals</li>
					<li>Structuring comprehensive partnership and vendor agreements</li>
				</ul>

				<div class="cta-section">
					<p>Need corporate legal counsel or facing an industrial dispute? Contact us for a strategic legal consultation.</p>
					<a href="/contact" class="cta-button">Get Legal Help</a>
				</div>
			</div>

			<!-- Sidebar Services Links -->
			<aside class="service-sidebar">
				<div class="sidebar-box">
					<h3>Our Services</h3>
					<nav class="services-nav">
						<a href="/court-marriage" class="service-link">
							Court Marriage Registration
						</a>
						<a href="/cyber-lawyers" class="service-link">
							Cyber Crime Lawyer
						</a>
						<a href="/criminal-lawyers" class="service-link">
							Criminal Lawyer
						</a>
						<a href="/corporate-lawyers" class="service-link active">
							Corporate & Industrial Disputes
						</a>
						<a href="/consumer-lawyers" class="service-link">
							Consumer Protection Lawyer
						</a>
						<a href="/civil-lawyers" class="service-link">
							Civil Lawyer
						</a>
						<a href="/revenue-matters" class="service-link">
							Revenue &amp; Administrative Matters
						</a>
						<a href="/property-registration" class="service-link">
							Property Registration
						</a>
						<a href="/notary-lawyer" class="service-link">
							Notary Lawyer
						</a>
					</nav>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.service-detail-section {
		background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
		padding: 2rem 1rem 4rem;
		min-height: 100vh;
	}

	.service-detail-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Hero Image */
	.service-hero {
		width: 100%;
		height: 400px;
		border-radius: 12px;
		overflow: hidden;
		margin-bottom: 3rem;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 0.12);
	}

	.service-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Content Wrapper */
	.service-content-wrapper {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2rem;
	}

	/* Main Content */
	.service-main-content h1 {
		font-size: 2.5rem;
		font-weight: 900;
		color: #0f172a;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.service-main-content h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #0f172a;
		margin: 2.5rem 0 1rem 0;
		line-height: 1.3;
	}

	.intro-text {
		font-size: 1.1rem;
		color: #475569;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.service-main-content p {
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1rem;
		font-size: 1rem;
	}

	.service-features,
	.benefits-list,
	.complaint-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem 0;
	}

	.service-features li,
	.benefits-list li,
	.complaint-list li {
		padding: 0.75rem 0 0.75rem 2rem;
		position: relative;
		color: #475569;
		line-height: 1.6;
	}

	.service-features li::before,
	.benefits-list li::before,
	.complaint-list li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #0ea5a4;
		font-weight: bold;
		font-size: 1.1rem;
	}

	.service-features li strong {
		color: #0f172a;
	}

	.approach-list {
		padding-left: 2rem;
		color: #475569;
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.approach-list li {
		margin-bottom: 0.75rem;
		color: #475569;
	}

	.approach-list li::marker {
		color: #0ea5a4;
		font-weight: bold;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #f0fffe 0%, #e0f7f6 100%);
		padding: 2rem;
		border-radius: 12px;
		margin-top: 2.5rem;
		border-left: 4px solid #0ea5a4;
		text-align: center;
	}

	.cta-section p {
		font-size: 1.05rem;
		color: #0f172a;
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.cta-button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background: #0ea5a4;
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(14, 165, 164, 0.2);
	}

	.cta-button:hover {
		background: #0d8e8d;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(14, 165, 164, 0.3);
	}

	/* Sidebar */
	.service-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: white;
		padding: 1.5rem;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(15, 23, 42, 0.08);
		position: sticky;
		top: 100px;
		height: fit-content;
	}

	.sidebar-box h3 {
		font-size: 1.1rem;
		font-weight: 800;
		color: #0f172a;
		margin: 0 0 1rem 0;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e2e8f0;
	}

	/* Services Navigation */
	.services-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.service-link {
		display: block;
		padding: 0.75rem 1rem;
		color: #475569;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
		border-left: 3px solid transparent;
		font-size: 0.95rem;
	}

	.service-link:hover {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		transform: translateX(4px);
	}

	.service-link.active {
		background: #f0fffe;
		color: #0ea5a4;
		border-left-color: #0ea5a4;
		font-weight: 600;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.service-content-wrapper {
			grid-template-columns: 1fr 280px;
		}

		.service-main-content h1 {
			font-size: 2rem;
		}

		.service-hero {
			height: 300px;
		}
	}

	@media (max-width: 768px) {
		.service-detail-section {
			padding: 1.5rem 1rem 3rem;
		}

		.service-content-wrapper {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.sidebar-box {
			position: static;
		}

		.service-main-content h1 {
			font-size: 1.6rem;
		}

		.service-main-content h2 {
			font-size: 1.3rem;
		}

		.service-hero {
			height: 250px;
			margin-bottom: 2rem;
		}

		.services-nav {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
		}

		.service-link {
			font-size: 0.9rem;
			padding: 0.6rem 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.service-detail-section {
			padding: 1rem;
		}

		.service-main-content h1 {
			font-size: 1.3rem;
		}

		.service-main-content h2 {
			font-size: 1.1rem;
			margin-top: 1.75rem;
		}

		.service-hero {
			height: 200px;
			margin-bottom: 1.5rem;
		}

		.intro-text {
			font-size: 1rem;
		}

		.cta-section {
			padding: 1.5rem 1rem;
		}

		.services-nav {
			grid-template-columns: 1fr;
		}

		.sidebar-box {
			padding: 1rem;
		}
	}
</style>
